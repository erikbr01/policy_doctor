# Copy to .env and fill in values before running ./deploy/deploy_study_stack.sh.
#
# Generate a password hash:
#   python3 -c "import hashlib; print(hashlib.sha256(b'yourpassword').hexdigest())"

# ── App passwords (optional — blank = open access) ──────────────────────────
APP_PASSWORD_SHA256=
SURVEY_PASSWORD_SHA256=


# ── Survey response storage ──────────────────────────────────────────────────
# Host path bind-mounted into the survey and demo containers.
# Production: set this to the persistent disk mount point (see setup_data_disk.sh).
# Local testing: default (./survey_responses) works out of the box.
# SURVEY_RESPONSES_DIR=/mnt/data/survey_responses

# ── Subdomain routing (nginx proxy) ─────────────────────────────────────────
# Defaults are for local testing. For production on behavior-graphs.com:
#   STUDY_DOMAIN=study.behavior-graphs.com
#   DEMO_DOMAIN=demo.behavior-graphs.com
STUDY_DOMAIN=study.localhost
DEMO_DOMAIN=demo.localhost

# Host port nginx binds to locally. Override if 80 is in use.
# HTTP_PORT=8080

# ── Cloudflare Tunnel ────────────────────────────────────────────────────────
# No env vars needed — the tunnel is configured entirely via
# deploy/cloudflared/config.yml (see config.yml.example).
# Use the --tunnel flag with deploy_study_stack.sh:
#   ./deploy/deploy_study_stack.sh --tunnel
