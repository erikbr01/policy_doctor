# Copy to .env and fill in values before running ./deploy/deploy_study_stack.sh.
#
# Generate a password hash:
#   python3 -c "import hashlib; print(hashlib.sha256(b'yourpassword').hexdigest())"

# ── App passwords (optional — blank = open access) ──────────────────────────
APP_PASSWORD_SHA256=
SURVEY_PASSWORD_SHA256=

# ── Survey response storage ─────────────────────────────────────────────────
# GCS bucket name. Blank = save to a local volume.
SURVEY_GCS_BUCKET=
# Path to a GCP service-account key JSON. On a GCP VM with the right IAM
# role, leave blank (the metadata server provides ADC automatically).
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/key.json

# ── Subdomain routing (nginx proxy) ────────────────────────────────────────
# The nginx proxy routes traffic by Host header to the survey or demo
# container. For local testing the *.localhost defaults work on most
# systems out of the box; otherwise either:
#   - add to /etc/hosts:  127.0.0.1  study.localhost demo.localhost
#   - or use the public wildcard:  study.lvh.me / demo.lvh.me
# For production, point real DNS A records at this host.
STUDY_DOMAIN=study.localhost
DEMO_DOMAIN=demo.localhost

# Host ports nginx binds to. Override if 80/443 are in use locally.
# HTTP_PORT=8080
# HTTPS_PORT=8443

# ── TLS (only needed for the docker-compose.tls.yml override) ───────────────
# Used by deploy/init_letsencrypt.sh when requesting certs.
LETSENCRYPT_EMAIL=
