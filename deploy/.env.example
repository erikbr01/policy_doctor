# Copy to .env and fill in values before running deploy_both.sh
#
# Generate a password hash:
#   python3 -c "import hashlib; print(hashlib.sha256(b'yourpassword').hexdigest())"

# Password for the graph-demo app (leave blank for open access)
APP_PASSWORD_SHA256=

# Password for the survey app (leave blank for open access)
SURVEY_PASSWORD_SHA256=

# GCS bucket for storing survey responses (leave blank to save locally)
# Create with: gsutil mb gs://your-bucket-name
SURVEY_GCS_BUCKET=

# Path to GCP service account key JSON (for non-VM deployments)
# On a GCP VM with the right IAM role, leave blank (uses metadata server ADC)
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/key.json
